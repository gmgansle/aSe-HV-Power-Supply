	(text "Redundant Battery Supplies with 2A Fuses, \nPolarity Protection, Bulk Filtering, and Bleed. \n\nEach Battery should be between 8.0V and 22.0V,\nand of the same type of chemistry, cell count,\nand roughly the voltage level (battery quality).\n\nOptimized for either LiFePO4 or 6S Li Batteries."
		(exclude_from_sim no)
		(at 45.72 29.21 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "88110573-9be5-4f91-a746-7e4d76f41b42")
	)
